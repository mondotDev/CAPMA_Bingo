rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isCapmaAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function entryKeysAllowed(data) {
      return data.keys().hasOnly([
        "eventId",
        "ownerUid",
        "emailKey",
        "name",
        "company",
        "email",
        "normalizedEmail",
        "selectedSquares",
        "markedSquareIds",
        "completed",
        "completedAt",
        "prizeEntryEligible",
        "createdAt",
        "updatedAt",
        "winnerLocked",
        "winnerLockedAt",
        "winnerLockedBy",
      ]);
    }

    function optionalStringFieldValid(data, fieldName) {
      return !(fieldName in data) || data[fieldName] is string;
    }

    function entryShapeValid(data, entryId, eventId) {
      return entryKeysAllowed(data)
        && data.eventId == eventId
        && data.emailKey == entryId
        && data.normalizedEmail == entryId
        && data.name is string
        && data.company is string
        && data.email is string
        && data.selectedSquares is list
        && data.markedSquareIds is list
        && data.completed is bool
        && data.prizeEntryEligible is bool
        && data.winnerLocked is bool
        && data.winnerLockedBy is string
        && optionalStringFieldValid(data, "ownerUid")
        && data.createdAt != null
        && data.updatedAt != null;
    }

    function completionLifecycleValid(data) {
      return (
        !data.completed
        && data.completedAt == null
        && data.prizeEntryEligible == false
      ) || (
        data.completed
        && data.completedAt != null
        && data.prizeEntryEligible == true
      );
    }

    function winnerLifecycleValid(data) {
      return (
        !data.winnerLocked
        && data.winnerLockedAt == null
        && data.winnerLockedBy == ""
      ) || (
        data.winnerLocked
        && data.winnerLockedAt != null
        && data.winnerLockedBy is string
      );
    }

    function attendeeFieldsValid(entryId) {
      return request.resource.data.eventId == resource.data.eventId
        && request.resource.data.emailKey == resource.data.emailKey
        && request.resource.data.normalizedEmail == resource.data.normalizedEmail
        && request.resource.data.name == resource.data.name
        && request.resource.data.company == resource.data.company
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.winnerLocked == resource.data.winnerLocked
        && request.resource.data.winnerLockedAt == resource.data.winnerLockedAt
        && request.resource.data.winnerLockedBy == resource.data.winnerLockedBy
        && (!("ownerUid" in resource.data) || request.resource.data.ownerUid == resource.data.ownerUid)
        && request.resource.data.emailKey == entryId
        && request.resource.data.normalizedEmail == entryId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "selectedSquares",
          "markedSquareIds",
          "completed",
          "completedAt",
          "prizeEntryEligible",
          "updatedAt",
        ]);
    }

    function attendeeCreateValid(entryId, eventId) {
      return isSignedIn()
        && entryShapeValid(request.resource.data, entryId, eventId)
        && completionLifecycleValid(request.resource.data)
        && request.resource.data.selectedSquares == request.resource.data.markedSquareIds
        && request.resource.data.completed == false
        && request.resource.data.completedAt == null
        && request.resource.data.prizeEntryEligible == false
        && request.resource.data.winnerLocked == false
        && request.resource.data.winnerLockedAt == null
        && request.resource.data.winnerLockedBy == "";
    }

    function migrationEntryExists(eventId, emailKey) {
      return getAfter(
        /databases/$(database)/documents/events/$(eventId)/entries/$(emailKey)
      ).data.emailKey == emailKey
        && getAfter(
          /databases/$(database)/documents/events/$(eventId)/entries/$(emailKey)
        ).data.normalizedEmail == emailKey;
    }

    function eventUpdateValid() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "boardSize",
          "squares",
        ])
        && request.resource.data.boardSize == 4
        && request.resource.data.squares is list
        && request.resource.data.squares.size() == 16;
    }

    match /events/{eventId} {
      allow read: if true;
      allow update: if isCapmaAdmin() && eventUpdateValid();
      allow create, delete: if false;

      match /entries/{entryId} {
        allow get: if isCapmaAdmin() || isSignedIn();
        allow list: if isCapmaAdmin();
        allow create: if isCapmaAdmin() || attendeeCreateValid(entryId, eventId);
        allow update: if isCapmaAdmin()
          || (
            isSignedIn()
            && !resource.data.completed
            && entryShapeValid(request.resource.data, entryId, eventId)
            && completionLifecycleValid(request.resource.data)
            && winnerLifecycleValid(request.resource.data)
            && attendeeFieldsValid(entryId)
          );
        allow delete: if isCapmaAdmin();
      }

      match /emailIndex/{emailKey} {
        allow get: if isSignedIn();
        allow list: if isCapmaAdmin();
        allow create, update: if isCapmaAdmin();
        allow delete: if isCapmaAdmin() || (isSignedIn() && migrationEntryExists(eventId, emailKey));
      }
    }

    match /admins/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, create, update, delete: if false;
    }
  }
}
